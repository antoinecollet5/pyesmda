@article{evensenSamplingStrategiesSquare2004,
  title = {Sampling Strategies and Square Root Analysis Schemes for the {{EnKF}}},
  author = {Evensen, Geir},
  year = 2004,
  month = dec,
  journal = {Ocean Dynamics},
  volume = {54},
  number = {6},
