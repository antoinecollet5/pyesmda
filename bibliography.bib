@article{yinOptimalEnsembleSize2015,
  title = {Optimal Ensemble Size of Ensemble {{Kalman}} Filter in Sequential Soil Moisture Data Assimilation},
  author = {Yin, Jifu and Zhan, Xiwu and Zheng, Youfei and Hain, Christopher R. and Liu, Jicheng and Fang, Li},
  year = 2015,
  journal = {Geophysical Research Letters},
  volume = {42},
  number = {16},
  pages = {6710--6715},
  issn = {1944-8007},
  doi = {10.1002/2015GL063366},
  urldate = {2024-01-14},
  abstract = {The ensemble Kalman filter (EnKF) has been extensively applied in sequential soil moisture data assimilation to improve the land surface model performance and in turn weather forecast capability. Usually, the ensemble size of EnKF is determined with limited sensitivity experiments. Thus, the optimal ensemble size may have never been reached. In this work, based on a series of mathematical derivations, we demonstrate that the maximum efficiency of the EnKF for assimilating observations into the models could be reached when the ensemble size is set to 12. Simulation experiments are designed in this study under ensemble size cases 2, 5, 12, 30, 50, 100, and 300 to support the mathematical derivations. All the simulations are conducted from 1 June to 30 September 2012 over southeast USA (from -90{$^\circ$}W, 30{$^\circ$}N to -80{$^\circ$}W, 40{$^\circ$}N) at 25 km resolution. We found that the simulations are perfectly consistent with the mathematical derivation. This optical ensemble size may have theoretical implications on the implementation of EnKF in other sequential data assimilation problems.},
  copyright = {\copyright 2015. The Authors.},
  langid = {english},
  keywords = {data assimilation,ensemble Kalman filter,ensemble size},
  file = {/home/acollet/Documents/ZOTERO/storage/2M4KE4KI/Yin et al. - 2015 - Optimal ensemble size of ensemble Kalman filter in.pdf;/home/acollet/Documents/ZOTERO/storage/U8RMKPCX/2015GL063366.html}
}
